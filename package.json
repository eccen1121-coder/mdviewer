{
  "name": "mdviewer",
  "version": "1.3.9",
  "description": "A Markdown viewer and editor built for AI Agent Managers",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:win": "electron-builder --win"
  },
  "keywords": [
    "markdown",
    "viewer",
    "editor"
  ],
  "author": "HSF <product-dev@homestudioframer.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^3.6.0",
    "dompurify": "^3.1.0",
    "highlight.js": "^11.10.0",
    "jsdom": "^25.0.0",
    "marked": "^12.0.0",
    "marked-highlight": "^2.1.0",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.homestudioframer.mdviewer",
    "productName": "MDViewer",
    "copyright": "Copyright © 2025 HSF",
    "icon": "assets/icon.icns",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "MDViewer",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/marked/marked.min.js",
      "node_modules/@xterm/xterm/**/*",
      "node_modules/@xterm/addon-fit/**/*",
      "node_modules/node-pty/**/*",
      "node_modules/node-addon-api/**/*"
    ]
  }
}
